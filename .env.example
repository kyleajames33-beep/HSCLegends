# Supabase project: HSCScienceSyd (shared with hscscience.com.au)
# These are PUBLIC keys (safe in the client). Get them from
# Supabase dashboard -> Settings -> API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
# Web Push public key (from `npx web-push generate-vapid-keys`). Private key lives
# only in the send-push edge function, never in the client.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=B...
